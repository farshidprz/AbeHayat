# Environment Variables for Abe Hayaat App
# Copy this file to .env.local and fill in your values

# =====================
# EMAIL SETTINGS (Gmail)
# =====================
# Your Gmail address
GMAIL_USER=your-email@gmail.com
# Gmail App Password (NOT your regular password)
# Get it at: https://myaccount.google.com/apppasswords
GMAIL_PASS=your-app-password
# Where to send registration notifications
ADMIN_EMAIL=your-email@gmail.com

# =====================
# SUPABASE (Free Database)
# =====================
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# =====================
# ADMIN DASHBOARD
# =====================
# Password to access the admin dashboard
ADMIN_PASSWORD=your-secure-password
